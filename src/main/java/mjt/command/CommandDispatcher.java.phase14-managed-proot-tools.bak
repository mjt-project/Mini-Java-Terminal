        if (lower.equals("proot distro") || lower.equals("proot distro show") || lower.equals("proot distro status")) return "proot-distro-show";
        if (lower.equals("proot distro catalog")) return "proot-distro-catalog";
        if (lower.equals("proot distro list")) return "proot-distro-list";
        if (lower.equals("proot distro engine install")) return "proot-distro-engine-install";
        if (lower.startsWith("proot distro engine update")) return "proot-distro-engine-update " + raw.substring("proot distro engine update".length()).trim();
        if (lower.startsWith("proot distro install ")) return "proot-distro-install " + raw.substring("proot distro install ".length()).trim();
        if (lower.startsWith("proot distro job ")) return "proot-distro-job " + raw.substring("proot distro job ".length()).trim();
        if (lower.startsWith("proot distro activate ")) return "proot-distro-activate " + raw.substring("proot distro activate ".length()).trim();
        if (lower.startsWith("proot distro remove ")) return "proot-distro-remove " + raw.substring("proot distro remove ".length()).trim();
        if (lower.startsWith("proot set ")) return "proot-set " + raw.substring("proot set ".length()).trim();
