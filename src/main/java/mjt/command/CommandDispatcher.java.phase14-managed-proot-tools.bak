    private void startMinecraftTarget() throws IOException {
        String activeProfile = context.stateStore().get("minecraft.active", "smp").trim();
        startMinecraftTarget(activeProfile);
    }

    private void startMinecraftTarget(String argument) throws IOException {
        String clean = normalizeProfileName(argument);
        if (!clean.isBlank() && getMinecraftProfileNames().contains(clean)) {
            startMinecraftProfile(clean);
            return;
        }

        if (!argument.isBlank() && !looksLikeShellCommand(argument) && context.stateStore().has("minecraft.profile." + clean + ".workdir")) {
            startMinecraftProfile(clean);
            return;
        }

        if (!argument.isBlank() && looksLikeShellCommand(argument)) {
            String activeProfile = normalizeProfileName(context.stateStore().get("minecraft.active", "smp"));
            context.minecraftProcessManagerService().startProfile(activeProfile, argument);
            routeMode = RouteMode.MINECRAFT;
            autoStartBotIfEnabled();
            return;
        }

        startMinecraftProfile(context.stateStore().get("minecraft.active", "smp"));
    }

    private void startMinecraftProfile(String rawProfile) throws IOException {
        String profile = normalizeProfileName(rawProfile);
        if (profile.isBlank()) {
            profile = "smp";
        }

        context.minecraftProcessManagerService().startProfile(profile);
        routeMode = RouteMode.MINECRAFT;
        autoStartBotIfEnabled();
    }

    private boolean looksLikeShellCommand(String argument) {
        String lower = argument == null ? "" : argument.trim().toLowerCase();
        return lower.contains(" ")
                || lower.endsWith(".sh")
                || lower.startsWith("bash ")
                || lower.startsWith("sh ")
                || lower.startsWith("java ")
                || lower.startsWith("./");
    }

    private void startTarget(String name, String command) throws IOException {
        startTarget(name, command, context.runtimeConfig().getCurrentDir());
    }

    private void startTarget(String name, String command, Path workdir) throws IOException {
        context.targetProcessService().start(
                name,
                command,
                workdir
        );
    }

    private void shutdownServices() {
        try { context.cloudflareTunnelService().stopAll(); } catch (Exception ignored) {}
        try { context.minecraftProcessManagerService().stopAll(); } catch (Exception ignored) {}
        try { context.keepAliveBotService().stop(); } catch (Exception ignored) {}
        try { context.sshServerService().stop(); } catch (Exception ignored) {}
        try { context.panelService().stop(); } catch (Exception ignored) {}
        try { context.gatewayService().stop(); } catch (Exception ignored) {}
        try { context.httpsService().stop(); } catch (Exception ignored) {}
        try { context.httpService().stop(); } catch (Exception ignored) {}
    }

    private void autoStartBotIfEnabled() {
        if (!context.stateStore().getBoolean("bot.enabled", false)) {
            return;
        }

        if (!context.stateStore().getBoolean("bot.autoStartWithMinecraft", true)) {
            return;
        }

        context.keepAliveBotService().start();
    }

    private void autoStopBotIfEnabled() {
        if (context.stateStore().getBoolean("bot.autoStopWithMinecraft", true)) {
            context.keepAliveBotService().stop();
        }
    }

