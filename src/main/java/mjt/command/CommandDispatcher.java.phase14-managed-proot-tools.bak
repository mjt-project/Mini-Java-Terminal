    private void useMinecraftProfile(String rawProfile) throws IOException {
        String profile = normalizeProfileName(rawProfile);
        if (profile.isBlank()) {
            System.out.println(RED + "Usage: .mjt minecraft profile use <name>" + RESET);
            return;
        }
        if (!getMinecraftProfileNames().contains(profile)) {
            System.out.println(RED + "Profile not found: " + profile + RESET);
            return;
        }
        context.stateStore().set("minecraft.active", profile);
        System.out.println(GREEN + "[Minecraft] Active profile = " + profile + RESET);
    }

    private void addMinecraftProfile(String raw) throws IOException {
        String[] parts = raw.trim().split("\\s+", 3);
        if (parts.length < 3) {
            System.out.println(RED + "Usage: .mjt minecraft profile add <name> <workdir> <command>" + RESET);
            System.out.println("Example: .mjt minecraft profile add velocity /home/container/server/Minecraft/Velocity bash start.sh");
            return;
        }
        String profile = normalizeProfileName(parts[0]);
        if (profile.isBlank()) {
            System.out.println(RED + "Invalid profile name." + RESET);
            return;
        }
        List<String> profiles = getMinecraftProfileNames();
        if (!profiles.contains(profile)) {
            profiles.add(profile);
        }
        context.stateStore().set("minecraft.profiles", String.join(",", profiles));
        context.stateStore().set("minecraft.profile." + profile + ".type", "minecraft");
        context.stateStore().set("minecraft.profile." + profile + ".workdir", parts[1]);
        context.stateStore().set("minecraft.profile." + profile + ".command", parts[2]);
        context.stateStore().set("minecraft.profile." + profile + ".stop", "stop");
        Files.createDirectories(Paths.get(parts[1]).toAbsolutePath().normalize());
        System.out.println(GREEN + "[Minecraft] Added profile: " + profile + RESET);
    }

    private void installMinecraft(String raw) throws IOException {
        List<String> args = splitArgs(raw);
        boolean acceptEula = args.remove("--accept-eula") || args.remove("--eula");
        boolean force = args.remove("--force");

        if (args.size() < 2) {
            System.out.println(RED + "Usage: .mjt minecraft install <velocity|paper|purpur> <profile> [version] [build] [--accept-eula] [--force]" + RESET);
            System.out.println("Example: .mjt minecraft install velocity velocity latest");
            System.out.println("Example: .mjt minecraft install paper smp latest --accept-eula");
            System.out.println("Example: .mjt minecraft install purpur lobby 1.21.10 --accept-eula");
            return;
        }

        String software = args.get(0);
        String profile = args.get(1);
        String version = args.size() >= 3 ? args.get(2) : "latest";
        String build = args.size() >= 4 ? args.get(3) : "latest";

        try {
            context.minecraftInstallerService().install(software, profile, version, build, acceptEula, force);
            System.out.println(GREEN + "[Minecraft] Install finished. Start with: .mjt minecraft start " + normalizeProfileName(profile) + RESET);
            if (!acceptEula && !software.equalsIgnoreCase("velocity")) {
                System.out.println(YELLOW + "[Minecraft] Paper/Purpur needs EULA acceptance before first start." + RESET);
            }
        } catch (Exception e) {
            System.out.println(RED + "[Minecraft Installer] Error: " + e.getMessage() + RESET);
            throw e instanceof IOException ? (IOException) e : new IOException(e);
        }
    }

    private List<String> splitArgs(String raw) {
        String text = raw == null ? "" : raw.trim();
        List<String> args = new ArrayList<>();
        StringBuilder current = new StringBuilder();
        boolean quoted = false;
        char quote = 0;
        for (int i = 0; i < text.length(); i++) {
            char c = text.charAt(i);
            if ((c == '"' || c == '\'') && (!quoted || quote == c)) {
                quoted = !quoted;
                quote = quoted ? c : 0;
                continue;
            }
            if (Character.isWhitespace(c) && !quoted) {
                if (current.length() > 0) {
                    args.add(current.toString());
                    current.setLength(0);
                }
                continue;
            }
            current.append(c);
        }
        if (current.length() > 0) args.add(current.toString());
        return args;
    }

