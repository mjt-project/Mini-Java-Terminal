    private List<String> getMinecraftProfileNames() {
        String raw = context.stateStore().get("minecraft.profiles", "velocity,smp,lobby").trim();
        List<String> profiles = new ArrayList<>();
        for (String item : raw.split(",")) {
            String clean = normalizeProfileName(item);
            if (!clean.isBlank() && !profiles.contains(clean)) {
                profiles.add(clean);
            }
        }
        return profiles;
    }

    private String normalizeProfileName(String name) {
        if (name == null) {
            return "";
        }
        return name.trim().toLowerCase().replaceAll("[^a-z0-9_-]", "");
    }

