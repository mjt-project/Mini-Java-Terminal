        printTitle("Website Migration");
        System.out.println("  The legacy HTTP site manager and per-site Quick Tunnel workflow are retired.");
        System.out.println("  New websites are PRoot guest services managed from the panel or .mjt service.");
        System.out.println();
        printSection("1. Static Site (requires python3 in the guest rootfs)");
        printCommand(".mjt service add docs static /home/container/server/docs python3 -m http.server $MJT_SERVICE_PORT --bind $MJT_SERVICE_HOST", "Register static files");
        printCommand(".mjt service set docs port 8080", "Keep the origin on loopback");
        printCommand(".mjt service set docs public-hostname docs.example.com", "Set hostname metadata");
        printCommand(".mjt service start docs", "Start inside PRootFS");
        printCommand(".mjt service publish docs", "Create/update managed Tunnel route");
        printSection("2. Node / Java / Python Applications");
        printCommand(".mjt service add api node /home/container/server/api npm run start", "Register a Node service");
        printCommand(".mjt service add app java /home/container/server/app java -jar app.jar", "Register a Java service");
        printCommand(".mjt service add worker python /home/container/server/worker python3 app.py", "Register a Python service");
        System.out.println();
        System.out.println(YELLOW + "Legacy HTTP commands remain available only for an existing local site during migration." + RESET);
        System.out.println(YELLOW + "Quick Tunnel guest-site commands no longer create temporary public endpoints." + RESET);
        System.out.println();
    }

