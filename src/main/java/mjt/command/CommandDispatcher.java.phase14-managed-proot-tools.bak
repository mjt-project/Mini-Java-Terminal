    private void handleMinecraftSet(String command) {
        String raw = command.substring("minecraft-set ".length()).trim();
        int firstSpace = raw.indexOf(' ');
        if (firstSpace <= 0) {
            System.out.println(RED + "Usage: .mjt minecraft set <key> <value>" + RESET);
            System.out.println("Example: .mjt minecraft set workdir /home/container/server/Minecraft/smp");
            System.out.println("Example: .mjt minecraft set command bash start.sh");
            return;
        }
        String key = raw.substring(0, firstSpace).trim().toLowerCase();
        String value = raw.substring(firstSpace + 1).trim();
        String realKey;
        switch (key) {
            case "workdir":
            case "dir":
                realKey = "minecraft.workdir";
                break;
            case "command":
            case "start-command":
                realKey = "minecraft.start-command";
                break;
            case "active":
            case "profile":
                realKey = "minecraft.active";
                value = normalizeProfileName(value);
                break;
            default:
                System.out.println(RED + "Invalid Minecraft key: " + key + RESET);
                return;
        }
        try {
            context.stateStore().set(realKey, value);
            System.out.println(GREEN + "[Minecraft] Saved " + realKey + " = " + value + RESET);
        } catch (Exception e) {
            System.out.println(RED + "[Minecraft] Error: " + e.getMessage() + RESET);
        }
    }

