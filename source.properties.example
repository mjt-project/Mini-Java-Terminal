# MJT Runtime Bundle source (one native architecture per MJT host)
# Copy the two amd64 fields to one of:
#   1) /home/container/MJT/system/proot-distro/runtime/source.properties
#   2) MJT_RUNTIME_BUNDLE_AMD64_URL + MJT_RUNTIME_BUNDLE_AMD64_SHA256 environment variables
#   3) POST /api/v1/distros/runtime/config authenticated with the MJT panel token.
#
# The ZIP must be published by the MJT project owner. Never use an unverified
# third-party URL. The SHA-256 below is the SHA-256 of the ZIP archive itself.

bundle.amd64.url=https://REPLACE-WITH-YOUR-RELEASE-HOST/mjt-runtime-linux-amd64-v1.0.0.zip
bundle.amd64.sha256=REPLACE-WITH-64-LOWERCASE-HEX-CHARACTERS

# Leave ARM64 blank on an x86_64 deployment. MJT only supports native CPU mode.
bundle.arm64.url=
bundle.arm64.sha256=
